VITE_SUPABASE_URL=your-supabase-url-here
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Keepa API key — used by the keepa-lookup edge function (server-side only).
# Set via: supabase secrets set KEEPA_API_KEY=your_key_here
# NOT a VITE_ var — never shipped to the browser.
KEEPA_API_KEY=your-keepa-api-key-here
